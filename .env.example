# Google OAuth2 (Obtener de Google Cloud Console)
GOOGLE_CLIENT_ID=669903110693-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# Backend Railway (PostgreSQL)
PGHOST=xxxx.proxy.rlwy.net
PGPORT=5432
PGUSER=postgres
PGPASSWORD=xxxx
PGDATABASE=railway

# Seguridad JWT
JWT_SECRET=tu_clave_secreta_aqui

# Frontend
NEXT_PUBLIC_API_URL=https://biosenseiot-production-e061.up.railway.app

# CORS Configuration (Separar múltiples orígenes por comas)
CORS_ALLOWED_ORIGINS=http://localhost,https://localhost,http://localhost:3000,capacitor://localhost,https://biosenseiot-production-e061.up.railway.app

# Control de inicialización del esquema (seguro e idempotente)
SQL_INIT_MODE=always
R2DBC_INIT_MODE=always